---
import DocPage from '../../components/DocPage.astro'; import CodeBlock from '../../components/CodeBlock.astro'; import Callout from '../../components/Callout.astro';
const loop = `gua::Context context;
bool loading = false;

// 毎フレーム
context.begin_frame(loading ? "loading" : "title");
ImGui::NewFrame();
ImGui::Begin("Game UI");

GuaImGui::Text(context, "Welcome##welcome");
if (GuaImGui::Button(context, "Start Game##start")) {
    loading = true;
}

ImGui::End();
ImGui::EndFrame();
context.end_frame();`;
---
<DocPage eyebrow="IMGUI / UI IMPLEMENTATION" title="UI実装の仕方" lead="既存のImGuiフレームループは維持する。自動化したいウィジェットだけGuaImGui経由で描画する。" description="Dear ImGui UIをGua対応にする方法。" section="imgui">
  <h2>ビルドする</h2><CodeBlock title="PowerShell" lang="powershell" code={`cmake --preset windows-msvc-debug\ncmake --build --preset windows-msvc-debug\n.\\build\\windows-msvc-debug\\examples\\cpp-imgui\\Debug\\gua-cpp-imgui-example.exe`} />
  <h2>フレームを公開する</h2><CodeBlock title="game_ui.cpp" lang="cpp" code={loop} /><Callout title="##の後ろが安定ID"><p><code>Start Game##start</code>は画面上に「Start Game」と表示され、Semantic UI Treeでは<code>start</code>として識別される。翻訳で表示文言が変わってもIDを維持できる。</p></Callout>
  <h2>対応ウィジェット</h2><CodeBlock title="代表的な呼び出し" lang="cpp" code={`GuaImGui::Button(context, "save", "保存");\nGuaImGui::Text(context, "Ready##status");\nGuaImGui::InputText(context, "Password##password", password, true);\nGuaImGui::Checkbox(context, "Sound##sound", soundEnabled);\nGuaImGui::Combo(context, "Region##region", selected, regions);`} />
  <Callout kind="warn" title="生のImGui呼び出しは自動収集されない"><p><code>ImGui::Button</code>だけで描いた要素はGuaのツリーに現れない。自動化対象には<code>GuaImGui</code>ファサードを使う。</p></Callout>
  <h2>Inspectorへ公開する</h2><p>サンプルは<code>BridgeServer</code>を起動し、毎フレーム<code>bridge.publish_snapshot()</code>を呼ぶ。接続先は既定で<code>ws://127.0.0.1:8765</code>だ。</p>
</DocPage>
