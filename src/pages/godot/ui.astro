---
import DocPage from '../../components/DocPage.astro'; import CodeBlock from '../../components/CodeBlock.astro'; import Callout from '../../components/Callout.astro';
const gd = `extends Control

const GuaAutoAdapterScript := preload(
  "res://addons/gua/gua_auto_adapter.gd"
)

var ui := GuaAutoAdapterScript.new()

func _ready() -> void:
  ui.attach(self)
  ui.update("title")
  ui.start_inspector_bridge(8765)

func _process(_delta: float) -> void:
  ui.update("title")`;
const cs = `public partial class Main : Control
{
    private readonly GuaGodotRuntime _gua = new();

    public override void _Ready()
    {
        BuildUi();
        _gua.Attach(this);
        _gua.SyncAttachedTree("title");
        _gua.StartInspectorBridge(8765);
    }

    public override void _Process(double delta)
        => _gua.SyncAttachedTree("title");

    public override void _ExitTree() => _gua.Dispose();
}`;
---
<DocPage eyebrow="GODOT / UI IMPLEMENTATION" title="UI実装の仕方" lead="UIをGua用に書き直す必要はない。標準Controlを組み、ルートControlを自動収集アダプターへ渡す。" description="Godot UIへGuaアダプターを導入する方法。" section="godot">
  <h2>GDScriptで導入する</h2><ol class="steps"><li><strong>ネイティブ拡張をビルドする</strong><CodeBlock title="PowerShell" lang="powershell" code={`cmake --preset windows-msvc-debug\ncmake --build --preset windows-msvc-debug --target gua-godot`} /></li><li><strong>アダプターを明示的にpreloadする</strong><p><code>class_name</code>の登録順に依存しないため、サンプルと同じ明示的なpreloadを使う。</p><CodeBlock title="main.gd" lang="gdscript" code={gd} /></li><li><strong>識別子を必要な箇所だけ固定する</strong><p>既定IDはNodePathから得られる。シーン構造を変えても維持したいIDはメタデータで指定する。</p><CodeBlock title="安定IDと機密入力" lang="gdscript" code={`name_input.set_meta("gua_id", "login-user")\npassword_input.set_meta("gua_id", "login-password")\npassword_input.set_meta("gua_sensitive", true)`} /></li></ol>
  <Callout title="二重登録は不要"><p>アダプターはルートControlから標準コントロールを再帰収集する。ボタンの<code>pressed</code>も監視し、外部クリック要求を通常のGodotシグナルへ流す。</p></Callout>
  <h2>C#で導入する</h2><p>Godot 4.7 .NETプロジェクトでは<code>GuaGodotRuntime</code>を保持し、シーンのライフサイクルに合わせて接続・同期・破棄する。</p><CodeBlock title="Main.cs" lang="csharp" code={cs} />
  <h2>収集される主なControl</h2><div class="grid-2"><div class="mini-card"><strong>入力</strong><p>LineEdit、TextEdit、CheckBox、OptionButton、ItemList</p></div><div class="mini-card"><strong>状態</strong><p>フォーカス、選択、値、スクロール、範囲、表示・有効状態</p></div></div>
  <Callout kind="warn" title="ポート競合"><p><code>8765</code>を別プロセスが使用中だとブリッジは開始できない。Godot出力の <code>Failed to start Gua Inspector bridge</code> を確認する。</p></Callout>
</DocPage>
